<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.vetechspringboot.mapper.UserMapper">

    <select id="selectUserByAge" resultType="com.example.vetechspringboot.entity.User">
        SELECT * FROM user
        WHERE age > #{age}
        ORDER BY id DESC
    </select>

</mapper>